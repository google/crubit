PROJECT_NAME           = "Crubit Generated Bindings"
OUTPUT_LANGUAGE        = English

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

QUIET                  = NO
WARNINGS               = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# TODO: add custom stylesheet b/523378095
HTML_EXTRA_STYLESHEET  =

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
SOURCE_BROWSER         = NO
VERBATIM_HEADERS       = NO

PREDEFINED             = CRUBIT_INTERNAL_RUST_TYPE(t,...)= \
                         CRUBIT_INTERNAL_SAME_ABI= \
                         CRUBIT_TRIVIAL_ABI= \
                         CRUBIT_VIEW= \
                         CRUBIT_LIFETIME_BOUND= \
                         "alignas(x)="
